<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Concert</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/huidigconcert.css">
</head>
<body>
    <header>
         <%- include('partials/header')%>
    </header>
    <main>
        <div>
            <a href="/"><img src="/images/terugpijl.png"></a>
            <h1>Huidig Concert</h1>
        </div>

        <section>
            <h2><%= event.artist %></h2>
            <img src="<%= event.image %>" alt="<%= event.artist %>" style="border-radius: 8px;">
            <form method="post" action="/addToFav">
                <input type="hidden" name="eventId" id="idinput" value="<%= event.id %>">
                <button id="favButton" type="submit">
                    <img src="/images/plus-button.svg" alt="plus">
                </button>
            </form>
            
            <p><%= event.city %>, <%= event.country %></p>
            <p><%= event.date %></p>
            <p><%= event.venue %></p>
            <p id="distanceText">Afstand berekenen...</p>
        </section>
        
        <div id="eventData"
            data-venue="<%= event.venue %>"
            data-city="<%= event.city %>"
            data-country="<%= event.country %>">
        </div>
        <div class="autoOpties">
            <a href="/buddy-zoeken?eventId=<%=event.id.trim()%>&name=<%=encodeURIComponent(event.artist)%>&venue=<%=encodeURIComponent(event.venue)%>&city=<%=encodeURIComponent(event.city)%>&country=<%=encodeURIComponent(event.country)%>&date=<%=event.date %>&time=<%=event.time%>&image=<%=encodeURIComponent(event.image)%>">Zoek een auto</a>
            <a href="/auto-aanbieden?eventId=<%=event.id.trim()%>&name=<%=encodeURIComponent(event.artist)%>&venue=<%=encodeURIComponent(event.venue)%>&city=<%=encodeURIComponent(event.city)%>&country=<%=encodeURIComponent(event.country)%>&date=<%=event.date %>&time=<%=event.time%>&image=<%=encodeURIComponent(event.image)%>">Bied auto aan</a>
        </div>
    </main>
    <footer>
    </footer>
    <script src="/scripts/script.js"></script>
</body>
</html>