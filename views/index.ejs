<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="css/index.css">
    <link rel="stylesheet" href="css/styles.css">
    <title>Concerten in de buurt</title>
</head>
<body>
    <header>
        <%- include('partials/header')%>
    </header>
    <main>
        <h1>Concerten in de buurt</h1>
        <section>
            <input type="search" placeholder="zoek een concert...">
            <button type="submit">
                <img src="images/searchicon.svg" alt="searchicon">
            </button>
            <button>Filter</button>
        </section> 
        <!-- Filtergedeelte -->
        <section id="filtergedeelte"> 
            <h2>Filters</h2>
            <h3>Plaats</h3>
            <input type="search" id="plaatsInput" placeholder="zoek een plaats...">
            <button>Zoek</button>
            <h3>Type muziek</h3>
            <input type="checkbox" id="rock" name="type_muziek" value="Rock">
            <label for="rock">Rock</label>
            <input type="checkbox" id="dance" name="type_muziek" value="Dance/Electronic">
            <label for="dance">Dance/Electronic</label>
            <input type="checkbox" id="country" name="type_muziek" value="Country">
            <label for="country">Country</label>
            <input type="checkbox" id="hiphop" name="type_muziek" value="Hip-hop/Rap">
            <label for="hiphop">Hip-hop/Rap</label>
            <input type="checkbox" id="other" name="type_muziek" value="Other">
            <label for="other">Other</label>
            <h3>Datum</h3>
            <input type="date" id="datumVan">
            <input type="date" id="datumTot">
            <button id="annuleer">Annuleer</button>            
            <button id="filterSubmit">Zoek</button>
        </section>
        <div id="results"></div>
    </main>
    <footer>
        <%- include('partials/menubalk')%>
    </footer>
    <script src="/scripts/script.js"></script>
</body>
</html>
