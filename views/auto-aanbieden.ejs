<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="login.css">
</head>
<body>
    <header>
    </header>
    <main>
        <h1>Auto Aanbieden</h1>
        <form action="/autoaanbieden" method="POST">
            <label>
                <h2>Welke auto heb je?</h2>
                <input name="auto" placeholder="Honda Civic" required>
            </label>
            <label>
                <h2>Hoeveel passen er in je auto?</h2>
                <input name="hoeveel" placeholder="5" required>
            </label>
            <label>
                <h2>Wil je zelf rijden?</h2> 
                <div>
                    <input class="radio"  id="rijdenyes" name="rijden" value="yes" type="radio" required>
                    <label for="rijdenyes">Ja</label>
                    <input class="radio" id="rijdenno" name="rijden" value="no" type="radio" required>
                    <label for="rijdenno">Nee</label>
                </div>
            </label>
            <label>
                <h2>Wat voor brandstof verbruikt je auto?</h2> 
                <div>
                    <input class="radio"  id="verbruiktbenzine" name="brandstof" value="benzine" type="radio" required>
                    <label for="verbruiktbenzine">Benzine</label>
                    <input class="radio" id="verbruiktdiesel" name="brandstof" value="diesel" type="radio" required>
                    <label for="verbruiktdiesel">Diesel</label>
                    <input class="radio" id="verbruiktelek" name="brandstof" value="elektrisch" type="radio" required>
                    <label for="verbruiktelek">Elektrisch</label>
                </div>
            </label>
            <button type="submit"><h2>Bied aan</h2></button>
        </form>
    </main>
    <footer>
    </footer>
</body>
</html>